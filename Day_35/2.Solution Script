"""
 Challenge 3: Find Missing Number 
Concepts: set() 
 Problem: 
nums = [1, 2, 4, 5] 
Expected Output: 
3 
Hint: 
Compare with full range using set difference.

"""

nums = [1, 2, 4, 5]
for i in range(min(nums), max(nums)):
    if i not in nums:
        print(f"Missing Number : {i}")
        break
        
"""
  Challenge 4: Group Words by First Letter 
Concepts: dict, setdefault() 
 Problem: 
words = ["apple", "ant", "banana", "bat"] 
Expected Output: 
{'a': ['apple', 'ant'], 'b': ['banana', 'bat']} 

"""
words = ["apple", "ant", "banana", "bat"]

# 1. ఖాళీ డిక్షనరీని క్రియేట్ చేయడం
result_dict = {}

# 2. లూప్ ద్వారా ప్రతి పదాన్ని ప్రాసెస్ చేయడం
for word in words:
    first_letter = word[0]
                           # a, b
    result_dict.setdefault(first_letter, []).append(word)
                           # key, default value
# 3. అవుట్‌పుట్ ప్రింట్ చేయడం
print(result_dict)


# for loop + indexing
words = ["apple", "ant", "banana", "bat"]
words_dict = {}
for word in words:
    if word[0] not in words_dict:
        words_dict[word[0]] = [word]
    else:
        words_dict[word[0]].append(word)
print(f"New Dictionary : {words_dict}")


"""
 Challenge 5: Remove Empty Values 
Concepts: dictionary comprehension 
Problem: 
data = {"a": 1, "b": None, "c": 3, "d": None} 
 Expected Output: 
{'a': 1, 'c': 3} 

"""
# dictionary comprehension
data = {"a": 1, "b": None, "c": 3, "d": None}

# Dictionary Comprehension ఉపయోగించి None వాల్యూస్ ఫిల్టర్ చేయడం
clean_data = {k: v for k, v in data.items() if v is not None}

print(clean_data)

# for loop
data = {"a": 1, "b": None, "c": 3, "d": None} 
new_data = {}
for info, values in data.items():
    if values != None:
        new_data[info] = values
print(new_data)

