
"""
Challenge 1: Flatten a Nested List 
Concepts: list comprehension 
 Problem: 
nested = [[1, 2], [3, 4], [5]] 
 Expected Output: 
[1, 2, 3, 4, 5]

"""
# for loop
nested = [[1, 2], [3, 4], [5]]
# new list for flatten nested list 
flat_list = []

for sublist in nested:
    for num in sublist:
        flat_list.append(num)
print(f"Flatten Nested List : {flat_list}")

#list comprehension
nested = [[1, 2], [3, 4], [5]]
new_list = [ num for sub_list in nested for num in sub_list ]
print(f"Flatten Nested List : {new_list}")

# while loop
nested = [[1, 2], [3, 4], [5]]
flat_list = []

i = 0  # బయటి లిస్ట్ ఇండెక్స్ (Outer loop index)

# 1. బయటి లూప్: పెద్ద లిస్ట్‌లోని ప్రతి సబ్-లిస్ట్‌ను చూస్తుంది
while i < len(nested):
    sublist = nested[i]
    j = 0  # లోపలి లిస్ట్ ఇండెక్స్ (Inner loop index)
    
    # 2. లోపలి లూప్: సబ్-లిస్ట్‌లోని ప్రతి నంబర్‌ను బయటకు తీస్తుంది
    while j < len(sublist):
        flat_list.append(sublist[j])
        j += 1  # లోపలి ఇండెక్స్‌ను పెంచుతుంది
        
    i += 1  # బయటి ఇండెక్స్‌ను పెంచుతుంది

print(flat_list)  # Output: [1, 2, 3, 4, 5]

