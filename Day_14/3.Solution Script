# sales analysis database
create database sales_analysis;

# database use
use sales_analysis;

# create table
CREATE TABLE Sales ( 
    sale_id INT PRIMARY KEY, 
    customer_name VARCHAR(50), 
    city VARCHAR(50), 
    product_name VARCHAR(50), 
    category VARCHAR(50), 
    quantity INT, 
    price DECIMAL(10,2), 
    sale_date DATE 
); 

